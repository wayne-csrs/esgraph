# Copy to config/vm.env and fill in your VM details.
# This file is gitignored — do not commit credentials.

# SSH target for deploy-vm.sh and debug-vm.sh
ESGRAPH_VM_HOST=192.168.1.100
ESGRAPH_VM_USER=esgraph

# Install path on the VM (must match lldb debug path)
ESGRAPH_INSTALL_PATH=/opt/esgraph

# Optional: host HTTP server for scenario payload delivery and exfil capture
# ESGRAPH_HOST_IP=192.168.1.50
# ESGRAPH_HOST_HTTP_PORT=8765
